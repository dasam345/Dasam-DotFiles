{
    "position": "top",
    "margin-top": 4,
    "modules-left": ["custom/apps", "clock", "mpris"],
    "modules-center": [ "hyprland/workspaces", "custom/notification"],
    "modules-right":[
        "tray",
        "pulseaudio",
        "network",
    ],


    //MODULES//

	"custom/apps": { 
	    "format": "Dasam",
		"font-family": "JetBrainsMono Nerd Font",
		"font-weight": 400,
		"on-click": "~/.config/rofi/scripts/menu.sh"
        // "on-click": "rofi -show drun"
	}, 

    "clock": {
        "format": "пАЧ  {:%H:%M}", // 24H
        "format-alt": "{:%A ољН %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "hyprland/workspaces": {
	    "persistent-workspaces": {"*": [ 1,2,3,4,5 ]},
	    "on-click": "activate",
	    "format": "{windows}",
	    "format-window-separator": " ",
	    "window-rewrite-default": "пБЩ",
	    "window-rewrite": {		
            "class<.*imv*.>": "пУ•",
            "class<.*bambustudio*.>": "у∞РЂ",
            "class<.*bitwarden*.>": "оі•",
            "class<.*handbrake*.>": "у∞ИЂ",
            "class<.*stremio*.>": "у±ЦП",
            "title<.*waydroid*.>": "оЬО",
            "class<.*grayjay*.>": "у±ЧЖ",
	    	"title<.*amazon.*>": "пЙ∞",
	    	"class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "оЭЕ",
	    	"class<zen>": "у∞∞Ј",
	    	"class<waterfox|waterfox-bin>": "оЇУ",
	    	"class<microsoft-edge>": "пКВ",
	    	"class<Chromium|Thorium|[Cc]hrome>": "пЙ®",
	    	"class<brave-browser>": "рЯ¶Б",
	    	"class<tor-browser>": "пН±",
	    	"class<firefox-developer-edition>": "рЯ¶К",
	    	"class<kitty|konsole>": "оЮХ",
	    	"class<kitty-dropterm>": "пД†",
	    	"class<com.mitchellh.ghostty>": "оЮХ",
	    	"class<org.wezfurlong.wezterm>": "о™Е",
            "class<org.omarchy.terminal>": "у∞ПЦ",
	    	"class<[Tt]hunderbird|[Tt]hunderbird-esr>": "пН∞",
	    	"class<eu.betterbird.Betterbird>": "пН∞",
	    	"title<.*gmail.*>": "у∞КЂ",
	    	"class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "оИЧ",
	    	"class<discord|[Ww]ebcord|Vesktop>": "пЗњ",
	    	"title<.*whatsapp.*>": "пИ≤",
        "title<.*zapzap.*>": "пИ≤",
	    	"title<.*messenger.*>": "пЙЯ",
	    	"title<.*facebook.*>": "пВЪ ",
	    	"title<.*reddit.*>": "пКБ",
	    	"title<.*ChatGPT.*>": "у∞Ъ©",
        "class<.*ChatGPT.*>": "у∞Ъ©",
	    	"title<.*deepseek.*>": "у∞Ъ©",
	    	"title<.*qwen.*>": "у∞Ъ©",
	    	"class<subl>": "у∞Е≥",
	    	"class<slack>": "пЖШ",
	    	"class<mpv>": "пНЃ",
	    	"class<celluloid|Zoom>": "пАљ",
	    	"class<Cider>": "у∞ОЖ ",
	    	"title<.*Picture-in-Picture.*>": "пФђ",
	    	"title<.*youtube.*>": "пЕ™",
	    	"class<vlc>": "у∞ХЉ",
	    	"title<.*cmus.*>": "пАБ",
	    	"class<[Ss]potify>": "пЖЉ",
	    	"class<virt-macodeger>": "о≠ї",
	    	"class<.virt-manager-wrapped>": "о≠ї",
	    	"class<virtualbox manager>": "рЯТљ",
	    	"title<virtualbox>": "рЯТљ",
	    	"class<remmina>": "рЯЦ•пЄП",
	    	"class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "у∞®Ю",
        "class<dev.zed.Zed>": "у∞µБ",
	    	"class<codeblocks>": "у∞Е©",
	    	"title<.*github.*>": "пДУ",
	    	"class<mousepad>": "пЕЬ",
	    	"class<libreoffice-writer>": "оЪ•",
	    	"class<libreoffice-startcenter>": " у∞ПЖ",
	    	"class<libreoffice-calc>": "пНї",
	    	"title<.*nvim ~.*>": "пНѓ",
        "class<org.gnome.Nautilus>": "у∞£Ж",
	    	"title<.*vim.*>": "оЯЕ",
	    	"title<.*figma.*>": "ољЗ",
	    	"title<.*jira.*>": "оЭЬ",
	    	"class<jetbrains-idea>": "оЮµ",
        "title<*.VSCode.*>": "у∞®Ю",
        "class<.*code.*>": "у∞®Ю",
	    	"class<obs|com.obsproject.Studio>": "оЃІ",
	    	"class<polkit-gnome-authentication-agent-1>": "у∞ТГ",
	    	"class<nwg-look>": "о≠Т",
	    	"class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "у±°Ђ",
	    	"class<steam>": "пЖґ",
	    	"class<thunar|nemo>": "у∞Э∞",	
        "class<Gparted>":"пГЗ",
	    	"class<gimp>": "пМЄ",
	    	"class<emulator>": "рЯУ±",
	    	"class<android-studio>": "пЕї",
       	"class<org.pipewire.Helvum>": "у∞УГ",
        "class<localsend>":"пЗ†",
        "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "у∞єЫ"
	    	}
	    },

    "tray": {
    "icon-size": 16,
    "spacing": 10,
    },

    "pulseaudio": {
    "format": "{icon} {volume}%",
    "on-click": "pavucontrol",
    "on-click-right": "pavucontrol",
    "tooltip-format": "Playing at {volume}%",
    "scroll-step": 5,
    "format-muted": "ої®",
    "format-icons": {
      "default": [
        "пА¶",
        "пАІ ",
        "пА® "
       ]
     }
    },

    "network": {
     "format-icons": ["у∞§ѓ", "у∞§Я", "у∞§Ґ", "у∞§•", "у∞§®"],
     "format": "{icon}",
     "format-wifi": "{icon}",
     "format-ethernet": "у∞МШ ethernet",
     "format-disconnected": "у∞§Ѓ",
     "tooltip-format-wifi": "{essid} ({frequency} GHz)\nвЗ£{bandwidthDownBytes}  вЗ°{bandwidthUpBytes}",
     "tooltip-format-ethernet": "вЗ£{bandwidthDownBytes}  вЗ°{bandwidthUpBytes}",
     "tooltip-format-disconnected": "Disconnected",
     "interval": 3,
     "spacing": 1,
     "on-click": "omarchy-launch-wifi"
    },

   "custom/notification": {
      "tooltip": true,
      "format": "<span size='16pt'>{icon}</span>",
      "format-icons": {
        "notification": "у±ЕЂ",
        "none": "у∞ВЬ",
        "dnd-notification": "у∞В†",
        "dnd-none": "у∞™У",
        "inhibited-notification": "у∞ВЫ",
        "inhibited-none": "у∞™С",
        "dnd-inhibited-notification": "у∞ВЫ",
        "dnd-inhibited-none": "у∞™С"
      },
      "return-type": "json",
      "exec-if": "command -v swaync-client >/dev/null 2>&1",
      "exec": "$HOME/.config/waybar/scripts/notification-status.sh",
      "on-click": "bash -lc 'command -v swaync-client >/dev/null 2>&1 && swaync-client -t -sw || notify-send \"SwayNC unavailable\"'",
      "on-click-right": "bash -lc 'command -v swaync-client >/dev/null 2>&1 && swaync-client -d -sw || notify-send \"SwayNC unavailable\"'",
      "escape": true
    },

    "mpris": {
	    "interval": 10,
	    "format": "{player_icon} {dynamic}",
	    "format-paused": "{status_icon} {artist}",
	    "on-click-middle": "playerctl play-pause",
	    "on-click": "playerctl previous",
	    "on-click-right": "playerctl next",
	    "scroll-step": 5.0,
	    "on-scroll-up": "$HOME/.config/hypr/scripts/volume.sh --inc",
	    "on-scroll-down": "$HOME/.config/hypr/scripts/volume.sh --dec",
	    "smooth-scrolling-threshold": 1,
	    "tooltip": true,
	    "tooltip-format": "{status_icon} {title}\nLeft Click: previous\nMid Click: Pause\nRight Click: Next",
	    "player-icons": {
	    	"chromium": "пЙ®",
	    	"default": "пАЭ",
	    	"firefox": "пЙ©",
	    	"kdeconnect": "пШЯ",
	    	"mopidy": "пАБ",
	    	"mpv": "у∞Рє",
	    	"spotify": "у∞ОЖ",
	    	"vlc": "у∞ХЉ",
	    },
	    "status-icons": {
	    	"paused": "пБМ",
	    	"playing": "пБЛ",
	    	"stopped": "пБН",
	    },
	    "dynamic-order": ["artist"],
	    "ignored-players": [ "zen"],
	    "max-length": 25,
    },

	"custom/screenrecording-indicator": {
		"format": "пАљ",
        "on-click": "kitty --title=Recorder sh -c '~/.config/hypr/scripts/screenrec.sh'",
        "signal": 8,
		"tooltip": false,
        "return-type": "json"
  },
}