{
    "font-family":"JetBrainsMono Nerd Font Propo", 
    "position": "top",
    "margin-top": 2,
    "modules-left": ["custom/arch", "custom/weather", "mpris"],
    "modules-center": ["clock", "hyprland/workspaces", "custom/notification"],
    "modules-right":[
        "tray",
        "group/right"
    ],


    //MODULES//

	"custom/arch": {
	    "exec": "~/.config/waybar/scripts/archicon.sh",
	    "exec-if": "true",
	    "format": "{}",
		"font-family": "JetBrainsMono Nerd Font Propo",
		"font-weight": 400,
		"on-click": "~/.config/rofi/scripts/menu.sh"
	},

    "custom/weather": {
        "exec": "~/.config/waybar/scripts/weather.sh",
        "return-type": "json",
        "interval": 1800,
        "format": "{}",
        "tooltip": true
    }, 

    "clock": {
        "format": " {:%H:%M}", // 24H
        "format-alt": " {:%A ŅĮŹ %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
          "default": "’åÆ",
          "active": "Ņ«┤",
          "urgent": "’ü¬",
          "empty": "Ņ«Ą",
        },
        "persistent-workspaces": {
          "1": [],
          "2": [],
          "3": [],
          "4": [],
          "5": []
        },
      },

    "tray": {
    "icon-size": 16,
    "spacing": 10,
    },

    "pulseaudio": {
    "format": "{icon} {volume}%",
    "on-click": "pavucontrol",
    "on-click-right": "pavucontrol",
    "tooltip-format": "Playing at {volume}%",
    "scroll-step": 5,
    "format-muted": "Ņ╗©",
    "format-icons": {
      "default": [
        "’Ć”",
        "’Ć¦ ",
        "’Ć© "
       ]
     }
    },

    "network": {
     "format-icons": ["¾░ż»", "¾░ż¤", "¾░żó", "¾░żź", "¾░ż©"],
     "format": "{icon}",
     "format-wifi": "{icon}",
     "format-ethernet": " ¾░īś ethernet",
     "format-disconnected": "¾░ż«",
     "tooltip-format-wifi": "{essid} ({frequency} GHz)\nŌćŻ{bandwidthDownBytes}  ŌćĪ{bandwidthUpBytes}",
     "tooltip-format-ethernet": "ŌćŻ{bandwidthDownBytes}  ŌćĪ{bandwidthUpBytes}",
     "tooltip-format-disconnected": "Disconnected",
     "interval": 3,
     "spacing": 1,
      "on-click": "~/.config/waybar/scripts/wifimenu.sh"
    },

   "custom/notification": {
      "tooltip": true,
      "format": "<span size='16pt'>{icon}</span>",
      "format-icons": {
        "notification": "¾▒ģ½",
        "none": "¾░é£",
        "dnd-notification": "¾░éĀ",
        "dnd-none": "¾░¬ō",
        "inhibited-notification": "¾░éø",
        "inhibited-none": "¾░¬æ",
        "dnd-inhibited-notification": "¾░éø",
        "dnd-inhibited-none": "¾░¬æ"
      },
      "return-type": "json",
      "exec-if": "command -v swaync-client >/dev/null 2>&1",
      "exec": "~/.config/waybar/scripts/notification-status.sh",
      "on-click": "bash -lc 'command -v swaync-client >/dev/null 2>&1 && swaync-client -t -sw || notify-send \"SwayNC unavailable\"'",
      "on-click-right": "bash -lc 'command -v swaync-client >/dev/null 2>&1 && swaync-client -d -sw || notify-send \"SwayNC unavailable\"'",
      "escape": true
    },

    "mpris": {
	    "interval": 10,
	    "format": "{player_icon} {dynamic}",
	    "format-paused": "{status_icon} {artist}",
	    "on-click-middle": "playerctl play-pause",
	    "on-click": "playerctl previous",
	    "on-click-right": "playerctl next",
	    "scroll-step": 5.0,
	    "on-scroll-up": "$HOME/.config/hypr/scripts/volume.sh --inc",
	    "on-scroll-down": "$HOME/.config/hypr/scripts/volume.sh --dec",
	    "smooth-scrolling-threshold": 1,
	    "tooltip": true,
	    "tooltip-format": "{status_icon} {title}\nLeft Click: previous\nMid Click: Pause\nRight Click: Next",
	    "player-icons": {
	    	"chromium": "’ē©",
	    	"default": "’ĆØ",
	    	"firefox": "’ē®",
	    	"kdeconnect": "’ś¤",
	    	"mopidy": "’Ćü",
	    	"mpv": "¾░É╣",
	    	"spotify": "¾░Äå",
	    	"vlc": "¾░Ģ╝",
	    },
	    "status-icons": {
	    	"paused": "’üī",
	    	"playing": "’üŗ",
	    	"stopped": "’üŹ",
	    },
	    "dynamic-order": ["artist"],
	    "ignored-players": [ "zen"],
	    "max-length": 25,
    },

    "group/right": {
	    "orientation": "inherit",
	    "modules": [ 
        "custom/resources",
        "pulseaudio",
        "custom/seprator#line",
        "network",
	    ]
    },  
 
    "custom/seprator#line": {
        "format": " |" 
    },

    "custom/resources": {
        "exec": "~/.config/waybar/scripts/resources.sh",
        "return-type": "json",
        "interval": 5,
        "format": "{}",
        "tooltip": true,
        "on-click": "kitty --class=btop btop"
    }
  
}