{
    "position": "top",
    "margin-top": 4,
    "modules-left": ["custom/apps", "clock", "mpris"],
    "modules-center": [ "hyprland/workspaces", "custom/notification"],
    "modules-right":[
        "tray",
        "pulseaudio",
        "network",
    ],


    //MODULES//

	"custom/apps": { 
	    "format": "Dasam",
		"font-family": "JetBrainsMono Nerd Font",
		"font-weight": 400,
		"on-click": "~/.config/rofi/scripts/menu.sh"
        // "on-click": "rofi -show drun"
	}, 

    "clock": {
        "format": "ÔÄó  {:%H:%M}", // 24H
        "format-alt": "{:%A ÓĹć %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "hyprland/workspaces": {
	    "persistent-workspaces": {"*": [ 1,2,3,4,5 ]},
	    "on-click": "activate",
	    "format": "{windows}",
	    "format-window-separator": " ",
	    "window-rewrite-default": "ÔĀô",
