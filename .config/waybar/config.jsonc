{
    "position": "top",
    "margin-top": 4,
    "modules-left": ["custom/apps", "clock", "mpris"],
    "modules-center": [ "hyprland/workspaces", "custom/notification"],
    "modules-right":[
        "tray",
        "pulseaudio",
        "network",
    ],


    //MODULES//

	"custom/apps": { 
	    "format": "Dasam",
		"font-family": "JetBrainsMono Nerd Font",
		"font-weight": 400,
		"on-click": "~/.config/rofi/scripts/menu.sh"
        // "on-click": "rofi -show drun"
	}, 

    "clock": {
        "format": "ΎΑΩ  {:%H:%M}", // 24H
        "format-alt": "{:%A Ό╜Ξ %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "hyprland/workspaces": {
	    "persistent-workspaces": {"*": [ 1,2,3,4,5 ]},
	    "on-click": "activate",
	    "format": "{windows}",
	    "format-window-separator": " ",
	    "window-rewrite-default": "ΎΒβ",
	    "window-rewrite": {		
            "class<.*imv*.>": "ΎΥξ",
            "class<.*bambustudio*.>": "≤░Ρτ",
            "class<.*bitwarden*.>": "Ό┤ξ",
            "class<.*handbrake*.>": "≤░Ιτ",
            "class<.*stremio*.>": "≤▒ΨΠ",
            "title<.*waydroid*.>": "ΌεΟ",
            "class<.*grayjay*.>": "≤▒ΩΗ",
	    	"title<.*amazon.*>": "ΎΚ░",
	    	"class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "ΌζΖ",
	    	"class<zen>": "≤░░╖",
	    	"class<waterfox|waterfox-bin>": "Ό║Υ",
	    	"class<microsoft-edge>": "ΎΛΓ",
	    	"class<Chromium|Thorium|[Cc]hrome>": "ΎΚρ",
	    	"class<brave-browser>": "ΏθοΒ",
	    	"class<tor-browser>": "ΎΞ▒",
	    	"class<firefox-developer-edition>": "ΏθοΛ",
	    	"class<kitty|konsole>": "ΌηΧ",
	    	"class<kitty-dropterm>": "ΎΕι",
	    	"class<com.mitchellh.ghostty>": "ΌηΧ",
	    	"class<org.wezfurlong.wezterm>": "ΌςΖ",
            "class<org.omarchy.terminal>": "≤░ΠΨ",
	    	"class<[Tt]hunderbird|[Tt]hunderbird-esr>": "ΎΞ░",
	    	"class<eu.betterbird.Betterbird>": "ΎΞ░",
	    	"title<.*gmail.*>": "≤░Λτ",
	    	"class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "ΌΙΩ",
	    	"class<discord|[Ww]ebcord|Vesktop>": "ΎΘ┐",
	    	"title<.*whatsapp.*>": "ΎΙ▓",
        "title<.*zapzap.*>": "ΎΙ▓",
	    	"title<.*messenger.*>": "ΎΚθ",
	    	"title<.*facebook.*>": "ΎΓγ ",
	    	"title<.*reddit.*>": "ΎΛΒ",
	    	"title<.*ChatGPT.*>": "≤░γσ",
        "class<.*ChatGPT.*>": "≤░γσ",
	    	"title<.*deepseek.*>": "≤░γσ",
	    	"title<.*qwen.*>": "≤░γσ",
	    	"class<subl>": "≤░Ζ│",
	    	"class<slack>": "ΎΗα",
	    	"class<mpv>": "ΎΞχ",
	    	"class<celluloid|Zoom>": "ΎΑ╜",
	    	"class<Cider>": "≤░ΟΗ ",
	    	"title<.*Picture-in-Picture.*>": "ΎΦυ",
	    	"title<.*youtube.*>": "ΎΖς",
	    	"class<vlc>": "≤░Χ╝",
	    	"title<.*cmus.*>": "ΎΑΒ",
	    	"class<[Ss]potify>": "ΎΗ╝",
	    	"class<virt-macodeger>": "Όφ╗",
	    	"class<.virt-manager-wrapped>": "Όφ╗",
	    	"class<virtualbox manager>": "ΏθΤ╜",
	    	"title<virtualbox>": "ΏθΤ╜",
	    	"class<remmina>": "ΏθΨξΎ╕Π",
	    	"class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "≤░ρη",
        "class<dev.zed.Zed>": "≤░╡Β",
	    	"class<codeblocks>": "≤░Ζσ",
	    	"title<.*github.*>": "ΎΕΥ",
	    	"class<mousepad>": "ΎΖε",
	    	"class<libreoffice-writer>": "Όγξ",
	    	"class<libreoffice-startcenter>": " ≤░ΠΗ",
	    	"class<libreoffice-calc>": "ΎΞ╗",
	    	"title<.*nvim ~.*>": "ΎΞψ",
        "class<org.gnome.Nautilus>": "≤░μΗ",
	    	"title<.*vim.*>": "ΌθΖ",
	    	"title<.*figma.*>": "Ό╜Θ",
	    	"title<.*jira.*>": "Όζε",
	    	"class<jetbrains-idea>": "Όη╡",
        "title<*.VSCode.*>": "≤░ρη",
        "class<.*code.*>": "≤░ρη",
	    	"class<obs|com.obsproject.Studio>": "Όχπ",
	    	"class<polkit-gnome-authentication-agent-1>": "≤░ΤΔ",
	    	"class<nwg-look>": "ΌφΤ",
	    	"class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "≤▒κτ",
	    	"class<steam>": "ΎΗ╢",
	    	"class<thunar|nemo>": "≤░ζ░",	
        "class<Gparted>":"ΎΔΘ",
	    	"class<gimp>": "ΎΝ╕",
	    	"class<emulator>": "ΏθΥ▒",
	    	"class<android-studio>": "ΎΖ╗",
       	"class<org.pipewire.Helvum>": "≤░ΥΔ",
        "class<localsend>":"ΎΘι",
        "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "≤░╣δ"
	    	}
	    },

    "tray": {
    "icon-size": 21,
    "spacing": 10,
    "icons": {
        "blueman": "bluetooth",
        "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
     }
    },

    "pulseaudio": {
    "format": "{icon} {volume}%",
    "on-click": "pavucontrol",
    "on-click-right": "pavucontrol",
    "tooltip-format": "Playing at {volume}%",
    "scroll-step": 5,
    "format-muted": "Ό╗ρ",
    "format-icons": {
      "default": [
        "ΎΑο",
        "ΎΑπ ",
        "ΎΑρ "
       ]
     }
    },

    "network": {
     "format-icons": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
     "format": "{icon}",
     "format-wifi": "{icon}",
     "format-ethernet": "≤░Να ethernet",
     "format-disconnected": "≤░νχ",
     "tooltip-format-wifi": "{essid} ({frequency} GHz)\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
     "tooltip-format-ethernet": "έΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
     "tooltip-format-disconnected": "Disconnected",
     "interval": 3,
     "spacing": 1,
     "on-click": "omarchy-launch-wifi"
    },

   "custom/notification": {
      "tooltip": true,
      "format": "<span size='16pt'>{icon}</span>",
      "format-icons": {
        "notification": "≤▒Ζτ",
        "none": "≤░Γε",
        "dnd-notification": "≤░Γι",
        "dnd-none": "≤░ςΥ",
        "inhibited-notification": "≤░Γδ",
        "inhibited-none": "≤░ςΣ",
        "dnd-inhibited-notification": "≤░Γδ",
        "dnd-inhibited-none": "≤░ςΣ"
      },
      "return-type": "json",
      "exec-if": "command -v swaync-client >/dev/null 2>&1",
      "exec": "~/.config/waybar/scripts/notification-status.sh",
      "on-click": "bash -lc 'command -v swaync-client >/dev/null 2>&1 && swaync-client -t -sw || notify-send \"SwayNC unavailable\"'",
      "on-click-right": "bash -lc 'command -v swaync-client >/dev/null 2>&1 && swaync-client -d -sw || notify-send \"SwayNC unavailable\"'",
      "escape": true
    },

    "mpris": {
	    "interval": 10,
	    "format": "{player_icon} {dynamic}",
	    "format-paused": "{status_icon} {artist}",
	    "on-click-middle": "playerctl play-pause",
	    "on-click": "playerctl previous",
	    "on-click-right": "playerctl next",
	    "scroll-step": 5.0,
	    "on-scroll-up": "$HOME/.config/hypr/scripts/volume.sh --inc",
	    "on-scroll-down": "$HOME/.config/hypr/scripts/volume.sh --dec",
	    "smooth-scrolling-threshold": 1,
	    "tooltip": true,
	    "tooltip-format": "{status_icon} {title}\nLeft Click: previous\nMid Click: Pause\nRight Click: Next",
	    "player-icons": {
	    	"chromium": "ΎΚρ",
	    	"default": "ΎΑζ",
	    	"firefox": "ΎΚσ",
	    	"kdeconnect": "Ύαθ",
	    	"mopidy": "ΎΑΒ",
	    	"mpv": "≤░Ρ╣",
	    	"spotify": "≤░ΟΗ",
	    	"vlc": "≤░Χ╝",
	    },
	    "status-icons": {
	    	"paused": "ΎΒΝ",
	    	"playing": "ΎΒΜ",
	    	"stopped": "ΎΒΞ",
	    },
	    "dynamic-order": ["artist"],
	    "ignored-players": [ "zen"],
	    "max-length": 25,
    },

	"custom/screenrecording-indicator": {
		"format": "ΎΑ╜",
        "on-click": "kitty --title=Recorder sh -c '~/.config/hypr/scripts/screenrec.sh'",
        "signal": 8,
		"tooltip": false,
        "return-type": "json"
  },
}