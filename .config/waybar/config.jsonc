	    	"class<thunar|nemo>": "ůįĚį",	
        "class<Gparted>":"ÔÉá",
	    	"class<gimp>": "ÔĆł",
	    	"class<emulator>": "ūüďĪ",
	    	"class<android-studio>": "ÔÖĽ",
       	"class<org.pipewire.Helvum>": "ůįďÉ",
