{
    "position": "top",
    "margin-top": 4,
    "modules-left": ["custom/apps", "clock", "mpris"],
    "modules-center": [ "hyprland/workspaces", "custom/notification"],
    "modules-right":[
        "tray",
        "custom/resources",
        "pulseaudio",
        "network",
    ],


    //MODULES//

	"custom/apps": {
	    "exec": "~/.config/waybar/scripts/nickname.sh",
	    "exec-if": "true",
	    "format": "{}",
		"font-family": "JetBrainsMono Nerd Font",
		"font-weight": 400,
		"on-click": "~/.config/rofi/scripts/menu.sh"
	}, 

    "clock": {
        "format": "´Çù  {:%H:%M}", // 24H
        "format-alt": "{:%A ¯¢ì %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "hyprland/workspaces": {
	    "persistent-workspaces": {"*": [ 1,2,3,4,5 ]},
	    "on-click": "activate",
	    "format": "{windows}",
	    "format-window-separator": " ",
