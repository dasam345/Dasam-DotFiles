            "class<.*bambustudio*.>": "ůįźę",
            "class<.*bitwarden*.>": "Óī•",
            "class<.*handbrake*.>": "ůįąę",
            "class<.*stremio*.>": "ůĪĖŹ",
            "title<.*waydroid*.>": "Óúé",
            "class<.*grayjay*.>": "ůĪóÜ",
	    	"title<.*amazon.*>": "ÔČį",
