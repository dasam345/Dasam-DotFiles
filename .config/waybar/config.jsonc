	    	"title<virtualbox>": "­ƒÆ¢",
	    	"class<remmina>": "­ƒûÑ´©Å",
	    	"class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "¾░¿×",
        "class<dev.zed.Zed>": "¾░Áü",
